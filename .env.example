# Server
APP_ADDR=:8080
APP_DEBUG=0
STORE_PATH=./data/store.json
AUTH_SECRET=change-me-please

# PostgreSQL publish log (optional)
# Leave empty for local development if you don't have Postgres running.
# Set DATABASE_REQUIRED=1 to make startup fail when Postgres is unavailable.
DATABASE_URL=
DATABASE_REQUIRED=0

# 0G Storage
# If ZERO_G_PRIVATE_KEY is empty, publishing falls back to a local simulated reference.
ZERO_G_PRIVATE_KEY=
ZERO_G_EVM_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai
ZERO_G_INDEXER_RETRY_COUNT=2
ZERO_G_INDEXER_RETRY_INTERVAL_MS=750
ZERO_G_EXPLORER_BASE=https://chainscan-galileo.0g.ai
# Optional: speeds up publish_prepare; avoids probing ZGS nodes for flowAddress.
# 0G testnet (chainId 16602) example: 0x22e03a6a89b950f1c82ec5e74f8eca321a105296
ZERO_G_FLOW_CONTRACT_ADDRESS=
ZERO_G_UPLOAD_METHOD=min
ZERO_G_REPLICAS=1
ZERO_G_ZGS_NODES=
ZERO_G_RPC_TIMEOUT_MS=30000
ZERO_G_ZGS_PROBE_TIMEOUT_MS=3500

# Optional: only used for simulated mode reference prefix
ZERO_G_ENDPOINT=

# 0G Compute (Inference / Memory Distillation)
# Service URL can be the service root or an OpenAI-compatible base.
# If it does not contain /v1 or /v1/proxy, the server will append /v1/proxy automatically.
ZERO_G_COMPUTE_API_KEY=
ZERO_G_COMPUTE_SERVICE_URL=
ZERO_G_COMPUTE_MODEL=THUDM/GLM-5-FP8
ZERO_G_COMPUTE_TIMEOUT_MS=90000

# Notes:
# - LLM API keys are entered in the web UI and are not persisted server-side.
# - If you want to avoid sending keys to your backend, you should proxy model calls differently.

# x402 (Buyer)
# Used for programmatic x402 payments (server-side signer).
# WARNING: This is a private key. Use a dedicated low-balance key with strict limits.
X402_EVM_PRIVATE_KEY=
